# ==========================================================================
# Nick's Stack — baked ~/.hermes/.env  (NON-SECRET operational defaults only)
# ==========================================================================
# Byte-for-byte the operational (non-secret) settings from the working Hubert
# VM. NO API keys, tokens, phone numbers, or account data live here. Real
# secrets are appended by on_resume (from the Orgo vault / /root/.env) or
# written by the agent / the first-boot onboarding — never baked.
#
# Telegram + Latitude + Composio keys are added at runtime (see on_resume and
# nicks-stack-onboard.sh). Hermes resolves ${VAR} placeholders in config.yaml
# (e.g. the Composio x-consumer-api-key header) from THIS file at connect time.

# --- Browser / terminal tool operational defaults -------------------------
AGENT_BROWSER_EXECUTABLE_PATH=/usr/bin/google-chrome
TERMINAL_TIMEOUT=60
TERMINAL_LIFETIME_SECONDS=300
TERMINAL_MODAL_IMAGE=nikolaik/python-nodejs:python3.11-nodejs20
BROWSER_SESSION_TIMEOUT=300
BROWSER_INACTIVITY_TIMEOUT=120
BROWSERBASE_PROXIES=true
BROWSERBASE_ADVANCED_STEALTH=false
WEB_TOOLS_DEBUG=false
VISION_TOOLS_DEBUG=false
MOA_TOOLS_DEBUG=false
IMAGE_TOOLS_DEBUG=false

# --- Obsidian vault (matches the baked filesystem MCP server) -------------
OBSIDIAN_VAULT_PATH=/root/Documents/HermesVault

# --- Latitude observability: non-secret endpoint/service/env defaults ------
# The plugin no-ops until HERMES_LATITUDE_API_KEY + HERMES_LATITUDE_PROJECT are
# added at runtime. These three carry the baked defaults from the source VM.
HERMES_LATITUDE_ENDPOINT=https://ingest.latitude.so/v1/traces
HERMES_LATITUDE_SERVICE=hermes-agent
HERMES_LATITUDE_ENV=local
