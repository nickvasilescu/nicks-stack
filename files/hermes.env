# ==========================================================================
# Nick's Stack — baked ~/.hermes/.env  (NON-SECRET operational defaults only)
# ==========================================================================
# The operational (non-secret) settings from the working Dewey VM. NO API
# keys, tokens, phone numbers, or account data live here. Real secrets are
# appended by on_resume (from the Orgo vault / /root/.env), resolved from
# 1Password at every hermes start (secrets.onepassword in config.yaml), or
# written by the agent / the first-boot onboarding — never baked.
#
# Hermes resolves ${VAR} placeholders in config.yaml (MCP headers/env) from
# THIS file at connect time; unset vars just park that MCP server (WARN-only)
# until a key lands — then /mcp or the 5-min self-probe revives it.

# --- Browser / terminal tool operational defaults -------------------------
AGENT_BROWSER_EXECUTABLE_PATH=/usr/bin/google-chrome
TERMINAL_TIMEOUT=60
TERMINAL_LIFETIME_SECONDS=300
BROWSER_SESSION_TIMEOUT=300
BROWSER_INACTIVITY_TIMEOUT=120

# --- Obsidian vault (filesystem MCP + note-taking skills) -----------------
OBSIDIAN_VAULT_PATH=/root/Documents/HermesVault
WIKI_PATH=/root/Documents/HermesVault

# --- Latitude observability: non-secret defaults (Dewey contract) ----------
# The telemetry plugin no-ops until LATITUDE_API_KEY + LATITUDE_PROJECT are
# added at runtime (op/vault/chat). Same key drives the latitude MCP server.
LATITUDE_BASE_URL=https://ingest.latitude.so
LATITUDE_INGEST_URL=https://ingest.latitude.so/v1/traces
LATITUDE_SERVICE_NAME=hermes-agent
LATITUDE_HERMES_NO_CONTENT=true
LATITUDE_HERMES_TELEMETRY_ENABLED=true

# --- AgentPhone: non-secret defaults ---------------------------------------
AGENTPHONE_BASE_URL=https://api.agentphone.ai

# ==========================================================================
# Key contract — add these at runtime (1Password item "Hermes Agent Secrets"
# in vault "Hermes", the Orgo launch vault, or just tell the agent in chat).
# Names only; NEVER commit values.
# ==========================================================================
#   OP_SERVICE_ACCOUNT_TOKEN   1Password service account (goes in ~/.hermes/.op.env)
#   ORGO_API_KEY               orgo MCP — operate Orgo VMs (sk_live_…)
#   ORGO_DEFAULT_COMPUTER_ID   this VM's computer id (on_resume/vault/agent sets it)
#   COMPOSIO_CONSUMER_KEY      Composio MCP (ck_…) — 1000+ connected apps
#   AGENTMAIL_API_KEY          AgentMail MCP (am_…)
#   AGENTMAIL_INBOX            your agent's inbox address (…@agentmail.to)
#   AGENTPHONE_API_KEY         AgentPhone MCP + webhook bridge (sk_live_…)
#   AGENTPHONE_AGENT_ID        AgentPhone hosted agent id
#   AGENTPHONE_NUMBER_ID       AgentPhone provisioned number id
#   AGENTPHONE_NUMBER          the provisioned E.164 number (display/skills)
#   LATITUDE_API_KEY           Latitude tracing + MCP
#   LATITUDE_PROJECT           Latitude project slug
#   TELEGRAM_BOT_TOKEN         minted by the QR onboarding (or BotFather)
#   TELEGRAM_ALLOWED_USERS     numeric id allowlist (QR onboarding sets it)
#   TELEGRAM_HOME_CHANNEL      home chat id (QR onboarding sets it)
#   TELEGRAM_BOT_USERNAME      your bot's @username (QR onboarding sets it)
#   GITHUB_TOKEN / GH_TOKEN    GitHub PAT (gh CLI + git)
#   EXA_API_KEY                web-exa search backend
#   FIRECRAWL_API_KEY          web/browser firecrawl backends
#   BROWSER_USE_API_KEY        browser-browser-use cloud backend
#   XAI_API_KEY                xai plugin / grok
#   OPENROUTER_API_KEY         openrouter provider (fallback models)
#   HONCHO_API_KEY             honcho memory provider (flip memory.provider)
#   AI_GATEWAY_API_KEY         Vercel AI Gateway provider
#   MODEL_API_KEY              Meta Model API provider
#   X_APP_ONLY_BEARER_TOKEN    xapi-app-only MCP (X developer portal)
#   IDEABROWSER_KEY            ideabrowser MCP
#   VIDIQ_MCP_API_KEY          vidiq MCP
#   HERMES_SPOTIFY_CLIENT_ID   spotify plugin (PKCE; then `hermes auth spotify`)
#   DISCORD_BOT_TOKEN          only if you enable the discord-platform plugin
#   OWNER_EMAIL                your email — skills CC/notify this address
